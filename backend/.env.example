# --- Runtime ---
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Comma-separated list of allowed origins. Use `*` only for local dev.
FRONTEND_URI=http://localhost:5173

# --- Database ---
MONGO_URI=mongodb://localhost:27017/sharevault
MONGO_POOL_SIZE=50

# --- Logging ---
LOG_LEVEL=info

# --- Storage / Uploads ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=100
MAX_FILES_PER_UPLOAD=20
MAX_TEXT_BYTES=1048576

# --- Content lifecycle ---
CONTENT_TTL_SECONDS=86400
CLEANUP_INTERVAL_MS=3600000

# --- Rate limiting (per IP, per window) ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
UPLOAD_RATE_LIMIT_MAX=20

# --- Proxy / Admin ---
# Behind a load balancer? Set to the number of hops or "loopback" / "uniquelocal".
TRUST_PROXY=loopback
# Required to enable destructive admin endpoints. Leave unset to disable them.
ADMIN_TOKEN=
